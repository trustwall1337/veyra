# Veyra credentials — copy to .env and fill in. NEVER commit .env.
# All credentials are read from the environment only; none are ever passed on
# argv, written to artifacts, or sent to the AI in raw form.

# Supabase Management REST API token — read-only schema/storage/advisor reads.
SUPABASE_ACCESS_TOKEN=

# AWS credentials for the Bedrock loop driver (the default AI provider).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Mode B auto-synthesize ONLY (the default Mode B sub-mode): the service-role
# key lets Veyra create + clean up its own synthetic test users. Leave blank
# for read-only (Mode A) scans.
SUPABASE_SERVICE_ROLE_KEY=

# Mode B manifest sub-mode (opt-in): passwords for operator-declared test
# actors, referenced by name from the manifest's `password_env` fields.
# ALICE_PWD=
# BOB_PWD=
